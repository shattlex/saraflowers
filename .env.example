API_PORT=8787

# Public URL of frontend for YooKassa return_url
PUBLIC_BASE_URL=http://127.0.0.1:5173
JWT_SECRET=change_me

# PostgreSQL
# Example:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/saraflowers
DATABASE_URL=
# Verify Postgres TLS certificate (recommended for production)
# Set to false only for temporary local troubleshooting.
PG_SSL_REJECT_UNAUTHORIZED=true

# Bitrix24 incoming webhook base URL:
# Example: https://yourcompany.bitrix24.ru/rest/1/xxxxxxxxxxxxxxxx
BITRIX24_WEBHOOK_URL=

# Telegram bot config
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# YooKassa credentials
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# SMS provider (sms.ru)
SMSRU_API_ID=

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# OAuth (Yandex)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=

# Optional admin API protection token for manual order-status updates
ADMIN_API_TOKEN=

# Optional override for Vite dev proxy
VITE_API_BASE_URL=http://127.0.0.1:8787
